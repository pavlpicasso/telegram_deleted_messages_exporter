# Copy this file to config/secrets.env and fill in real values.
# config/secrets.env is ignored by git.

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHAT=@your_group_or_channel
TELEGRAM_SESSION=config/session
TELEGRAM_ADMIN_LOG_LIMIT=100000
TELEGRAM_MIN_TEXT_LENGTH=100
TELEGRAM_OUTPUT_FILE=deleted_messages.json
TELEGRAM_TEXT_ONLY=false
TELEGRAM_WITH_LINKS=false
TELEGRAM_DOWNLOAD_MEDIA=false
TELEGRAM_INCREMENTAL=false
TELEGRAM_MEDIA_DIR=media
TELEGRAM_SENDER_ID=
TELEGRAM_DELETED_BY=
TELEGRAM_HAS_MEDIA=false
TELEGRAM_HAS_LINKS=false
TELEGRAM_SORT_BY=none
TELEGRAM_SORT_ORDER=asc
TELEGRAM_RESOLVE_USERS=false
